{
  "name": "ene-data-vision-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,css,scss,json}\"",
    "stylelint": "stylelint \"src/**/*.{vue,css,scss}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "echo 'Prepare hook'"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "pinia": "^2.3.0",
    "echarts": "^5.6.0",
    "vue-echarts": "^7.0.3",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "vite": "^6.3.1",
    "vue-tsc": "^2.2.8",
    "typescript": "~5.7.3",
    "msw": "^2.7.3",
    "vitest": "^3.1.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^17.4.4",
    "@playwright/test": "^1.51.1",
    "eslint": "^9.24.0",
    "@eslint/js": "^9.24.0",
    "eslint-plugin-vue": "^9.33.0",
    "typescript-eslint": "^8.30.1",
    "vue-eslint-parser": "^9.4.3",
    "prettier": "^3.5.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "stylelint": "^16.18.0",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "postcss-html": "^1.8.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}